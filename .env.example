# Discord
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here

# 監視対象チャンネル（カンマ区切りで複数指定可）
SOURCE_CHANNEL_IDS=1234567890,9876543210

# 日報投稿先チャンネル
SUMMARY_CHANNEL_ID=1111111111

# 自動実行時刻（JST）
DAILY_HOUR=8
DAILY_MINUTE=0

# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
